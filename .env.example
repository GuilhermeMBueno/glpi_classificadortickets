# ============================================================
# Configuração — copie para .env e preencha com seus valores
#   cp .env.example .env
# NUNCA commite o arquivo .env (ele está no .gitignore).
# ============================================================

# URL da API REST do seu GLPI (habilite em Configurar → Geral → API)
GLPI_URL=https://glpi.suaempresa.com.br/apirest.php

# App-Token: Configurar → Geral → API → adicionar cliente de API
GLPI_APP_TOKEN=coloque_seu_app_token_aqui

# User-Token: Preferências do usuário → Tokens remotos → Regenerar
GLPI_USER_TOKEN=coloque_seu_user_token_aqui

# Chave da API do Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=coloque_sua_gemini_api_key_aqui

# ============ Configurações opcionais ============
# MODE=daemon                 # daemon (loop) ou once (uma execução)
# INTERVALO=60                # segundos entre ciclos
# LIMIT=50                    # nº máximo de chamados por ciclo
# CONFIANCA_MINIMA=0.70       # threshold para aplicar a sugestão da IA
# GEMINI_MODEL=gemini-2.5-flash-lite
# LOG_LEVEL=INFO              # DEBUG mostra ciclos vazios
# VERIFY_SSL=false            # true se o GLPI tiver certificado válido
